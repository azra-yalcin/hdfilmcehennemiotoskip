// ==UserScript==
// @name         HDFilmcehennemi Oynatıcı İçi Altyazı + 3 Dk Geçiş
// @namespace    http://tampermonkey.net/
// @version      7.0
// @description  Oynatıcı içindeki "Türkçe Altyazılı" butonunu bulur ve 3 dk kala diğer bölüme atlar.
// @match        *://*.hdfilmcehennemi.*/*
// @match        *://*/*
// @allFrames    true
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    const KAC_SANIYE_KALA = 160; // yaklasık 3 dakika olarak ayarlandi

    // Tıklama simülatörü
    const gercekTiklama = (element) => {
        if (!element) return;
        const event = new MouseEvent('click', { view: window, bubbles: true, cancelable: true });
        element.dispatchEvent(event);
    };

    if (window.top === window.self) {
        setInterval(() => {
            const playButonu = document.querySelector('.play-that-video');
            if (playButonu && playButonu.offsetParent !== null && !playButonu.hasAttribute('hidden')) {
                gercekTiklama(playButonu);
            }
        }, 2000);
        window.addEventListener('message', (event) => {
            if (event.data === 'gecis_vakti_geldi') {
                const sonrakiButon = document.querySelector('.next-episode');
                if (sonrakiButon && sonrakiButon.href) {
                    console.log("Script: 3 dakika kaldı! Yeni bölüme yönlendiriliyor...");
                    window.location.assign(sonrakiButon.href);
                }
            }
        });

    } else {
         let gecisTetiklendi = false;

        setInterval(() => {
            if (!window.hfcAltyaziSecildi) {
                const tumElementler = Array.from(document.querySelectorAll('div, span, button'));
                const altyaziButonu = tumElementler.find(el =>
                    el.textContent &&
                    el.textContent.trim() === 'Türkçe Altyazılı' &&  //burada dublaj altyazi tercihi
                    el.children.length === 0 // İç içe elementleri elemek için
                );

                if (altyaziButonu) {
                    console.log(" 'Türkçe Altyazılı' butonu bulundu, tıklanıyor...");
                    gercekTiklama(altyaziButonu);
                    window.hfcAltyaziSecildi = true; // Sadece 1 kere tıkla ki sürekli yenilemesin
                }
            }

            const video = document.querySelector('video');

            if (video && video.duration > 0) {
                const kalanZaman = video.duration - video.currentTime;

                if (!gecisTetiklendi && kalanZaman <= KAC_SANIYE_KALA && video.duration > 600) {
                    gecisTetiklendi = true;
                    console.log(" Script: Bitişe 3 dk kaldı, ana sayfaya geçiş !");
                    window.top.postMessage('gecis_vakti_geldi', '*');
                }
            }
        }, 1000); // Her saniye kontrol et
    }
})();
